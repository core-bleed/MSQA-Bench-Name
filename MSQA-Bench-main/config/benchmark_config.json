{
  "_comment": "MSQA-Bench Configuration",
  
  "dataset": {
    "input_qa_file": "data/consolidated_qa.jsonl",
    "text_dir": "data/extracted_text/bulk_40k",
    "output_dir": "benchmark",
    
    "splits": {
      "train_ratio": 0.85,
      "val_ratio": 0.10,
      "test_ratio": 0.05,
      "seed": 42
    },
    
    "quality_filters": {
      "min_question_length": 15,
      "max_question_length": 500,
      "min_answer_length": 20,
      "max_answer_length": 2000,
      "min_quality_score": 0.4,
      "deduplicate": true
    }
  },
  
  "metadata": {
    "use_api": false,
    "cache_dir": "benchmark/metadata_cache"
  },
  
  "retrieval": {
    "models": [
      {"name": "BM25", "type": "bm25"},
      {"name": "E5-base-v2",      "type": "embedding", "path": "intfloat/e5-base-v2"},
      {"name": "E5-large-v2",     "type": "embedding", "path": "intfloat/e5-large-v2"},
      {"name": "BGE-base-en-v1.5","type": "embedding", "path": "BAAI/bge-base-en-v1.5"},
      {"name": "BGE-large-en-v1.5","type": "embedding", "path": "BAAI/bge-large-en-v1.5"},
      {"name": "Nomic-Embed-v1.5","type": "embedding", "path": "nomic-ai/nomic-embed-text-v1.5"},
      {"name": "MSQA-E5-base",    "type": "embedding", "path": "models/fine_tuned_embeddings_e5_base_v2"},
      {"name": "MSQA-E5-large",   "type": "embedding", "path": "models/fine_tuned_embeddings_e5_large_v2"},
      {"name": "MSQA-BGE-base",   "type": "embedding", "path": "models/fine_tuned_embeddings_bge_base_en_v1.5"},
      {"name": "MSQA-BGE-large",  "type": "embedding", "path": "models/fine_tuned_embeddings_bge_large_en_v1.5"},
      {"name": "MSQA-Nomic",      "type": "embedding", "path": "models/fine_tuned_embeddings_nomic_embed_v1.5"}
    ],
    "top_k": 20,
    "eval_sample_size": 5000
  },
  
  "annotation": {
    "target_size": 500,
    "output_format": "csv",
    "guidelines_file": "benchmark/gold/annotation_guidelines.md"
  },
  
  "paper": {
    "tables_dir": "paper/figures/tables",
    "figures_dir": "paper/figures/plots"
  }
}
