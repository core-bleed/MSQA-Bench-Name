{
  "_comment": "QLoRA LLM Fine-Tuner Configuration (24GB GPU)",

  "input_jsonl": "data/consolidated_qa.jsonl",
  "output_dir": "models/fine_tuned_llms",
  "log_file": "logs/llm_finetuning.log",

  "base_model": "microsoft/Phi-3.5-mini-instruct",
  "max_seq_length": 1024,
  "trust_remote_code": true,

  "num_epochs": 1,
  "per_device_train_batch_size": 4,
  "per_device_eval_batch_size": 4,
  "gradient_accumulation_steps": 4,
  "learning_rate": 2e-4,
  "weight_decay": 0.01,
  "warmup_ratio": 0.03,
  "lr_scheduler_type": "cosine",
  "max_grad_norm": 0.3,

  "train_ratio": 0.85,
  "val_ratio": 0.10,
  "test_ratio": 0.05,
  "no_context_ratio": 0.3,
  "max_context_length": 1536,

  "min_question_length": 10,
  "max_question_length": 512,
  "min_answer_length": 20,
  "max_answer_length": 2048,
  "clean_answers": true,

  "lora_r": 64,
  "lora_alpha": 128,
  "lora_dropout": 0.05,
  "lora_target_modules": null,

  "load_in_4bit": true,
  "bnb_4bit_quant_type": "nf4",
  "bnb_4bit_use_double_quant": true,
  "bnb_4bit_compute_dtype": "bfloat16",

  "eval_steps": 5000,
  "save_steps": 5000,
  "save_total_limit": 3,
  "logging_steps": 10,
  "eval_strategy": "steps",

  "early_stopping_patience": 3,
  "early_stopping_threshold": 0.001,

  "eval_max_new_tokens": 256,
  "eval_temperature": 0.1,
  "eval_sample_size": 1000,

  "seed": 42,
  "bf16": true,
  "gradient_checkpointing": true,
  "optim": "paged_adamw_8bit",

  "subset_size": null,

  "models_to_train": [
    {
      "name": "qwen2.5_3b",
      "model_path": "Qwen/Qwen2.5-3B-Instruct",
      "max_seq_length": 1024,
      "per_device_train_batch_size": 4,
      "gradient_accumulation_steps": 4,
      "trust_remote_code": true,
      "enabled": false,
      "_note": "Tiny but strong; fast iteration, baseline reference"
    },
    {
      "name": "phi3.5_mini",
      "model_path": "microsoft/Phi-3.5-mini-instruct",
      "max_seq_length": 2048,
      "per_device_train_batch_size": 4,
      "gradient_accumulation_steps": 8,
      "trust_remote_code": true,
      "enabled": true,
      "_note": "3.8B params, excellent reasoning for its size"
    },
    {
      "name": "mistral_7b_v0.3",
      "model_path": "mistralai/Mistral-7B-Instruct-v0.3",
      "max_seq_length": 2048,
      "per_device_train_batch_size": 2,
      "gradient_accumulation_steps": 16,
      "trust_remote_code": false,
      "enabled": true,
      "_note": "Strong general-purpose 7B; proven fine-tuning target"
    },
    {
      "name": "llama3.1_8b",
      "model_path": "meta-llama/Llama-3.1-8B-Instruct",
      "max_seq_length": 2048,
      "per_device_train_batch_size": 2,
      "gradient_accumulation_steps": 16,
      "trust_remote_code": false,
      "enabled": false,
      "_note": "Gated repo; not in paper baselines (see paper Limitation L7). Set enabled=true once HF access is granted."
    },
    {
      "name": "qwen2.5_7b",
      "model_path": "Qwen/Qwen2.5-7B-Instruct",
      "max_seq_length": 2048,
      "per_device_train_batch_size": 2,
      "gradient_accumulation_steps": 16,
      "trust_remote_code": true,
      "enabled": true,
      "_note": "Competitive 7B with long context support"
    },
    {
      "name": "deepseek_r1_distill_7b",
      "model_path": "deepseek-ai/DeepSeek-R1-Distill-Qwen-7B",
      "max_seq_length": 2048,
      "per_device_train_batch_size": 2,
      "gradient_accumulation_steps": 16,
      "trust_remote_code": true,
      "enabled": true,
      "_note": "DeepSeek R1 distilled into Qwen2.5-7B; strong reasoning, 24GB-friendly with QLoRA"
    }
  ],

  "_training_tips": [
    "For 24GB GPU: 3B models use batch_size=4, 7B models use batch_size=2",
    "Start with subset_size=100 to validate the pipeline end-to-end",
    "If OOM, reduce per_device_train_batch_size and increase gradient_accumulation_steps",
    "Set gradient_checkpointing=true to save ~40% VRAM at cost of ~20% speed",
    "lora_r=64 with alpha=128 is a good default; try r=32 for faster training"
  ],

  "_data_split_info": {
    "train": "85% of data (hash % 100 < 85)",
    "val": "10% of data (85 <= hash % 100 < 95)",
    "test": "5% of data (hash % 100 >= 95)",
    "note": "Splits are deterministic and compatible with embedding trainer splits"
  }
}
